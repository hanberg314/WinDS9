<Window x:Class="WinDS9.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinDS9"
        Height="620"
        MinHeight="520"
        Width="980"
        MinWidth="820"
        AllowDrop="True"
        Drop="Window_Drop">
    <Grid Background="#F7F8FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="0,0,0,1" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                           Text="WinDS9"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#1D2733" />

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="DS9 executable"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Foreground="#354052" />
                <TextBox x:Name="Ds9PathBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,8,0" />
                <Button Grid.Row="2" Grid.Column="2" Content="Browse" Click="BrowseDs9_Click" />
                <Button Grid.Row="2" Grid.Column="3" Content="Save Path" Click="SavePath_Click" Margin="0" />

                <TextBlock x:Name="PathStatusText"
                           Grid.Row="4"
                           Grid.Column="0"
                           Grid.ColumnSpan="4"
                           TextWrapping="Wrap"
                           Foreground="#536171" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="1" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Open"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1D2733" />

                    <Button Grid.Row="2"
                            Content="Open FITS or event file"
                            Click="OpenFile_Click"
                            HorizontalAlignment="Left"
                            MinWidth="190" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="NewFrameCheck"
                                  Content="Open in new frame"
                                  VerticalAlignment="Center"
                                  Checked="SettingsChanged"
                                  Unchecked="SettingsChanged"
                                  Margin="0,0,18,0" />
                        <CheckBox x:Name="ReuseCheck"
                                  Content="Try running DS9"
                                  VerticalAlignment="Center"
                                  Checked="SettingsChanged"
                                  Unchecked="SettingsChanged" />
                    </StackPanel>

                    <TextBlock Grid.Row="6"
                               Text="Profile"
                               Foreground="#354052"
                               Margin="0,0,0,6" />
                    <ComboBox x:Name="ProfileCombo"
                              Grid.Row="7"
                              SelectionChanged="ProfileCombo_SelectionChanged"
                              VerticalAlignment="Top" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="1" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recent files"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1D2733" />

                    <ListBox x:Name="RecentFilesList"
                             Grid.Row="2"
                             MouseDoubleClick="RecentFilesList_MouseDoubleClick"
                             BorderBrush="#CAD2DD" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Open Selected" Click="OpenRecent_Click" />
                        <Button Content="Clear" Click="ClearRecent_Click" Margin="0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="0,1,0,0" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Timing log"
                           FontWeight="SemiBold"
                           Foreground="#1D2733" />
                <ListBox x:Name="LogList"
                         Grid.Row="2"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderBrush="#CAD2DD" />
            </Grid>
        </Border>
    </Grid>
</Window>
